{
    "name": "perimetre/perimetre-wp-tools",
    "description": "Operational tooling for Perimetre WordPress sites: status endpoint and remote login.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "Perimetre",
            "homepage": "https://perimetre.co"
        }
    ],
    "require": {
        "php": ">=8.1",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Perimetre\\WpTools\\": "src/"
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
